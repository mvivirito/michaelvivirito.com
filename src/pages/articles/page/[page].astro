---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPosts, PAGE_SIZE } from '../../../lib/blog';

export async function getStaticPaths() {
  const posts = await getPosts();
  const totalPages = Math.ceil(posts.length / PAGE_SIZE);
  const paths = [];
  // Page 1 lives at /articles; generate pages 2..N here.
  for (let p = 2; p <= totalPages; p++) {
    paths.push({
      params: { page: String(p) },
      props: { pageNum: p, totalPages, posts: posts.slice((p - 1) * PAGE_SIZE, p * PAGE_SIZE) },
    });
  }
  return paths;
}

const { pageNum, totalPages, posts } = Astro.props;
const newerHref = pageNum === 2 ? '/articles' : `/articles/page/${pageNum - 1}`;
---
<BlogLayout
  title={`Blog (page ${pageNum} of ${totalPages}) - Michael Vivirito`}
  description="Older posts from the blog — FreeBSD, NixOS, SRE, networking, and hardware builds."
  keywords="Michael Vivirito, blog, archive, FreeBSD, NixOS, SRE"
  canonical={`/articles/page/${pageNum}`}
>
  <header style="margin-bottom: 2rem;">
    <p class="text-muted" style="margin: 0 0 0.25rem; font-size: 0.875rem;"><a href="/articles">Blog</a> /</p>
    <h1 style="margin: 0;">Page {pageNum}</h1>
    <p class="text-muted">Page {pageNum} of {totalPages}</p>
  </header>

  <div style="display: flex; flex-direction: column; gap: 1.25rem;">
    {posts.map((post) => <PostCard post={post} />)}
  </div>

  <nav style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem;" aria-label="Pagination">
    <a href={newerHref} class="btn btn-secondary">← Newer posts</a>
    <span class="text-muted" style="font-size: 0.875rem;">Page {pageNum} of {totalPages}</span>
    {pageNum < totalPages
      ? <a href={`/articles/page/${pageNum + 1}`} class="btn btn-secondary">Older posts →</a>
      : <span></span>}
  </nav>
</BlogLayout>
