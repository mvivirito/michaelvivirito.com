---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPosts, PAGE_SIZE } from '../../lib/blog';

const posts = await getPosts();
const pagePosts = posts.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(posts.length / PAGE_SIZE);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://michaelvivirito.com/articles',
  name: 'Michael Vivirito — Blog',
  url: 'https://michaelvivirito.com/articles',
  author: { '@id': 'https://michaelvivirito.com/#michael' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.date.toISOString(),
    url: `https://michaelvivirito.com/articles/${p.id}`,
  })),
};
---
<BlogLayout
  title="Blog - Michael Vivirito"
  description="Writing on FreeBSD and pf networking, NixOS, SRE, the homelab, and the occasional hardware build."
  keywords="Michael Vivirito, blog, FreeBSD, pf, NixOS, SRE, homelab, networking, ESP32, WLED, mvivirito"
  canonical="/articles"
  jsonLd={jsonLd}
>
  <header style="margin-bottom: 2rem;">
    <h1 style="margin: 0;">Blog</h1>
    <p class="text-muted">FreeBSD and pf, NixOS, SRE, the homelab, and the occasional build log. {posts.length} posts.</p>
  </header>

  <div style="display: flex; flex-direction: column; gap: 1.25rem;">
    {pagePosts.map((post) => <PostCard post={post} />)}
  </div>

  {totalPages > 1 && (
    <nav style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem;" aria-label="Pagination">
      <span class="text-muted" style="font-size: 0.875rem;">Page 1 of {totalPages}</span>
      <a href="/articles/page/2" class="btn btn-secondary">Older posts →</a>
    </nav>
  )}

  <div style="margin-top: 2.5rem; text-align: center;">
    <a href="/tags" class="btn btn-secondary">Browse tags</a>
    <a href="/feed.xml" class="btn btn-secondary">RSS</a>
  </div>
</BlogLayout>
