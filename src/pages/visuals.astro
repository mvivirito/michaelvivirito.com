---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Visuals - CSS Art Gallery - Michael Vivirito"
  description="A collection of pure CSS visual art experiments - psychedelic patterns, impossible geometry, and optical illusions."
  canonical="/visuals"
>

  <!-- Header -->
  <section>
    <h1 class="text-center">CSS Visual Experiments</h1>
    <p class="text-center text-muted" style="max-width: 700px; margin: 0 auto 2rem;">
      A collection of visual art created with pure HTML and CSS. No images, no JavaScript, just code.
    </p>
  </section>

  <!-- Visual 1: Impossible Cube -->
  <section>
    <div class="visual-container">
      <h2 class="text-center">Impossible Cube</h2>
      <p class="text-center text-muted">Inspired by M.C. Escher's impossible geometry</p>
      <div class="visual-box">
        <div class="impossible-cube">
          <div class="cube-face cube-front"></div>
          <div class="cube-face cube-back"></div>
          <div class="cube-face cube-right"></div>
          <div class="cube-face cube-left"></div>
          <div class="cube-face cube-top"></div>
          <div class="cube-face cube-bottom"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual 2: Psychedelic Spiral -->
  <section>
    <div class="visual-container">
      <h2 class="text-center">Psychedelic Spiral</h2>
      <p class="text-center text-muted">Infinite rotating gradients</p>
      <div class="visual-box">
        <div class="psychedelic-spiral">
          <div class="spiral-layer spiral-1"></div>
          <div class="spiral-layer spiral-2"></div>
          <div class="spiral-layer spiral-3"></div>
          <div class="spiral-layer spiral-4"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual 3: 3D Corridor -->
  <section>
    <div class="visual-container">
      <h2 class="text-center">3D Corridor</h2>
      <p class="text-center text-muted">Perspective depth illusion</p>
      <div class="visual-box">
        <div class="corridor-3d">
          <div class="corridor-segment corridor-1"></div>
          <div class="corridor-segment corridor-2"></div>
          <div class="corridor-segment corridor-3"></div>
          <div class="corridor-segment corridor-4"></div>
          <div class="corridor-segment corridor-5"></div>
          <div class="corridor-vanish"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual 4: Tessellation Grid -->
  <section>
    <div class="visual-container">
      <h2 class="text-center">Tessellation Grid</h2>
      <p class="text-center text-muted">M.C. Escher style repeating patterns</p>
      <div class="visual-box">
        <div class="tessellation-grid"></div>
      </div>
    </div>
  </section>

  <!-- Visual 5: Magic Eye Pattern -->
  <section>
    <div class="visual-container">
      <h2 class="text-center">Magic Eye Pattern</h2>
      <p class="text-center text-muted">Stereogram-inspired repeating elements</p>
      <div class="visual-box">
        <div class="magic-eye-pattern"></div>
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section>
    <div class="card" style="max-width: 800px; margin: 2rem auto;">
      <h2>About These Visuals</h2>
      <p>
        All of these visual effects are created using pure CSS, no images, no canvas, no JavaScript.
        They demonstrate the power of modern CSS features like transforms, animations, gradients,
        and pseudo-elements.
      </p>
      <p class="text-muted" style="font-size: 0.875rem; margin-top: 1.5rem;">
        <strong>Note:</strong> These animations may be resource-intensive. If your browser feels sluggish,
        try viewing one section at a time.
      </p>
    </div>
  </section>

</BaseLayout>
