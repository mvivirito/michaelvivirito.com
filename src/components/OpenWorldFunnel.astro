---
interface Props {
  /** The article's slug (entry.id). Used to skip rendering on selected posts. */
  entrySlug?: string;
}

const { entrySlug } = Astro.props;

// Don't surface the funnel on the launch post itself; it already closes
// philosophically.
const SKIP_FOR = ['truly-open-sourcing-the-world'];
const shouldRender = !entrySlug || !SKIP_FOR.includes(entrySlug);
---
{shouldRender && (
  <div class="card" style="max-width: 800px; margin: 2rem auto 0;">
    <h3 style="margin-top: 0;">// be the change</h3>
    <p style="font-style: italic; color: var(--text-primary);">
      "People can be good. Let's work together to make a difference. A future
      where we are all continuously improving the world together."
    </p>
    <p class="text-muted" style="font-size: 0.9rem;">
      That thesis is why I'm building <a href="/openworld">OpenWorld</a>, a
      coordination layer for civic action. If any of it lands,
      <a href="/articles/truly-open-sourcing-the-world">there's more on why</a>.
    </p>
  </div>
)}
