---
// Recursive binary tree on a canvas: animated growth, mouse-sway, click to regrow.
---
<div class="viz-stage">
  <canvas id="viz-tree"></canvas>
  <span class="viz-hint">move to sway · click to regrow</span>
</div>

<style>
  .viz-stage { position: relative; height: clamp(320px, 46vw, 460px); border: 1px solid var(--border); border-radius: 12px; background: var(--bg2); overflow: hidden; }
  .viz-stage canvas { display: block; width: 100%; height: 100%; cursor: crosshair; }
  .viz-hint { position: absolute; right: .6rem; bottom: .5rem; font-size: .7rem; color: var(--t3); font-family: var(--font-mono); pointer-events: none; letter-spacing: .03em; }
</style>

<script>
  const canvas = document.getElementById('viz-tree');
  if (canvas instanceof HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0, H = 0, mouseX = 0.5, t = 0, time = 0, ratio = 0.76, running = false, raf = 0;

    function resize() {
      const r = canvas.getBoundingClientRect();
      W = r.width; H = r.height;
      canvas.width = Math.max(1, Math.floor(W * dpr));
      canvas.height = Math.max(1, Math.floor(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function branch(x, y, len, angle, depth, maxDepth, spread, wind) {
      if (depth > maxDepth || len < 2) return;
      const x2 = x + Math.cos(angle) * len;
      const y2 = y + Math.sin(angle) * len;
      const k = depth / maxDepth;
      ctx.strokeStyle = 'hsl(' + (145 - k * 35) + ' 80% ' + (28 + k * 52) + '%)';
      ctx.lineWidth = Math.max(0.6, (maxDepth - depth) * 0.6);
      ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(x2, y2); ctx.stroke();
      const a = spread + Math.sin(depth * 1.3 + time) * 0.04 + wind;
      branch(x2, y2, len * ratio, angle - a, depth + 1, maxDepth, spread, wind);
      branch(x2, y2, len * ratio, angle + a, depth + 1, maxDepth, spread, wind);
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      const maxDepth = 11;
      const depth = reduce ? maxDepth : Math.round(2 + t * (maxDepth - 2));
      const wind = reduce ? 0 : Math.sin(time * 0.8) * 0.06;
      const spread = 0.34 + (mouseX - 0.5) * 0.5;
      branch(W / 2, H - 6, Math.min(W, H) * 0.2, -Math.PI / 2, 0, depth, spread, wind);
    }

    function tick() {
      if (!running) return;
      time += 0.016;
      if (t < 1) t = Math.min(1, t + 0.015);
      draw();
      raf = requestAnimationFrame(tick);
    }

    canvas.addEventListener('pointermove', (e) => {
      const r = canvas.getBoundingClientRect();
      mouseX = (e.clientX - r.left) / r.width;
      if (reduce) draw();
    });
    canvas.addEventListener('pointerdown', () => { t = 0; ratio = 0.68 + Math.random() * 0.12; });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) {
          if (reduce) { draw(); }
          else if (!running) { running = true; raf = requestAnimationFrame(tick); }
        } else { running = false; cancelAnimationFrame(raf); }
      });
    }, { threshold: 0.05 });

    const ro = new ResizeObserver(() => { resize(); draw(); });
    resize(); draw(); io.observe(canvas); ro.observe(canvas);
  }
</script>
