---
// Penrose triangle (impossible tribar), built parametrically: project one 3D bar,
// then rotate its 2D image by 120° three times so the ends meet impossibly.
---
<div class="viz-stage">
  <svg id="viz-penrose" viewBox="0 0 240 240" role="img" aria-label="Penrose impossible triangle"></svg>
  <span class="viz-hint">impossible tribar</span>
</div>

<style>
  .viz-stage { position: relative; height: clamp(320px, 46vw, 460px); border: 1px solid var(--border); border-radius: 12px; background: var(--bg2); overflow: hidden; display: grid; place-items: center; }
  #viz-penrose { width: min(78%, 360px); height: auto; filter: drop-shadow(0 0 14px rgba(34, 197, 94, .25)); animation: penrose-float 9s ease-in-out infinite; }
  @keyframes penrose-float { 0%, 100% { transform: translateY(-5px); } 50% { transform: translateY(5px); } }
  .viz-hint { position: absolute; right: .6rem; bottom: .5rem; font-size: .7rem; color: var(--t3); font-family: var(--font-mono); pointer-events: none; }
  @media (prefers-reduced-motion: reduce) { #viz-penrose { animation: none; } }
</style>

<script>
  const svg = document.getElementById('viz-penrose');
  if (svg) {
    const NS = 'http://www.w3.org/2000/svg';
    const iso = (x, y, z) => [(x - y) * 0.8660254, (x + y) * 0.5 - z];
    const s = 30, L0 = 2, L1 = 104;
    const faces = [
      { col: '#86efac', pts: [iso(L0, -s / 2, s / 2), iso(L1, -s / 2, s / 2), iso(L1, s / 2, s / 2), iso(L0, s / 2, s / 2)] },
      { col: '#22c55e', pts: [iso(L0, s / 2, s / 2), iso(L1, s / 2, s / 2), iso(L1, s / 2, -s / 2), iso(L0, s / 2, -s / 2)] },
      { col: '#15803d', pts: [iso(L1, -s / 2, s / 2), iso(L1, s / 2, s / 2), iso(L1, s / 2, -s / 2), iso(L1, -s / 2, -s / 2)] },
    ];
    const cx = 120, cy = 128;
    const rot = (p, a) => [p[0] * Math.cos(a) - p[1] * Math.sin(a), p[0] * Math.sin(a) + p[1] * Math.cos(a)];
    for (let i = 2; i >= 0; i--) {
      const ang = i * 2 * Math.PI / 3;
      faces.forEach((f) => {
        const poly = document.createElementNS(NS, 'polygon');
        const pts = f.pts.map((p) => { const r = rot(p, ang); return (r[0] + cx).toFixed(2) + ',' + (r[1] + cy).toFixed(2); }).join(' ');
        poly.setAttribute('points', pts);
        poly.setAttribute('fill', f.col);
        poly.setAttribute('stroke', '#04110a');
        poly.setAttribute('stroke-width', '2.5');
        poly.setAttribute('stroke-linejoin', 'round');
        svg.appendChild(poly);
      });
    }
  }
</script>
