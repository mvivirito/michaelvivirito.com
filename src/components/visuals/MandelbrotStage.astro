---
// Full-viewport Mandelbrot deep-zoom via PERTURBATION THEORY (WebGL2): a
// high-precision reference orbit (decimal.js) computed on the CPU and uploaded
// as a float texture; the shader iterates cheap FP32 deltas against it with
// SuperFractalThing-style rebasing, so zoom depth isn't capped by GPU floats.
// Plus an auto-playing Game-Boy Egyptian platformer + bouncing glyphs + sound.
---
<div class="mb-stage" id="mb-stage">
  <canvas id="viz-mandel"></canvas>
  <div class="mb-fade" id="mb-fade"></div>
  <div class="mb-hypno" id="mb-hypno"><svg viewBox="-50 -50 100 100" preserveAspectRatio="xMidYMid slice"><path id="mb-spiral"/></svg></div>

  <svg class="mb-defs" width="0" height="0"><defs>
    <linearGradient id="mbgrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#ff2bd6"/><stop offset="0.5" stop-color="#22d3ee"/><stop offset="1" stop-color="#a3ff12"/>
    </linearGradient>
  </defs></svg>

  <div class="mb-sky" id="mb-sky">
    <svg class="g" viewBox="0 0 100 100"><polygon points="50,6 94,90 6,90" fill="none" stroke="url(#mbgrad)" stroke-width="3"/><circle cx="50" cy="62" r="16" fill="none" stroke="url(#mbgrad)" stroke-width="3"/></svg>
    <svg class="g" viewBox="0 0 100 100"><circle cx="50" cy="50" r="44" fill="none" stroke="url(#mbgrad)" stroke-width="2.5"/><circle cx="50" cy="50" r="28" fill="none" stroke="url(#mbgrad)" stroke-width="2.5"/><circle cx="50" cy="50" r="12" fill="none" stroke="url(#mbgrad)" stroke-width="2.5"/></svg>
    <svg class="g" viewBox="0 0 100 100"><polygon points="50,4 92,27 92,73 50,96 8,73 8,27" fill="none" stroke="url(#mbgrad)" stroke-width="3"/></svg>
    <svg class="g" viewBox="0 0 100 100"><g fill="none" stroke="url(#mbgrad)" stroke-width="2.5"><circle cx="50" cy="50" r="18"/><circle cx="32" cy="50" r="18"/><circle cx="68" cy="50" r="18"/><circle cx="41" cy="34" r="18"/><circle cx="59" cy="34" r="18"/><circle cx="41" cy="66" r="18"/><circle cx="59" cy="66" r="18"/></g></svg>
    <svg class="g" viewBox="0 0 100 100"><polygon points="50,8 90,50 50,92 10,50" fill="none" stroke="url(#mbgrad)" stroke-width="3"/><polygon points="50,28 72,50 50,72 28,50" fill="url(#mbgrad)" opacity="0.5"/></svg>
  </div>

  <canvas id="viz-ground"></canvas>
  <button id="mb-sound" class="mb-sound" type="button">🔊 react to sound</button>
  <span class="viz-fallback" id="viz-mandel-fb" hidden>WebGL2 unavailable — your browser can't run the deep Mandelbrot dive.</span>
</div>

<style>
  .mb-stage { position: fixed; left: 0; right: 0; bottom: 0; top: 104px; z-index: 1; background: #020503; overflow: hidden; }
  .mb-stage canvas#viz-mandel { position: absolute; inset: 0; width: 100%; height: 100%; display: block; cursor: grab; touch-action: none; }
  .mb-stage canvas#viz-mandel:active { cursor: grabbing; }
  .mb-fade { position: absolute; inset: 0; background: #020503; opacity: 0; transition: opacity .45s ease; pointer-events: none; z-index: 2; }
  .mb-hypno { position: absolute; inset: 0; z-index: 1; pointer-events: none; opacity: .22; mix-blend-mode: screen; overflow: hidden; }
  .mb-hypno svg { position: absolute; top: 50%; left: 50%; width: 160vmax; height: 160vmax; transform-origin: center; animation: mb-spin-spiral 4s linear infinite; }
  #mb-spiral { fill: none; stroke: #bfead0; stroke-width: 1.5; }
  @keyframes mb-spin-spiral { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }
  .mb-defs { position: absolute; }
  .mb-sky { position: absolute; inset: 0; pointer-events: none; mix-blend-mode: screen; z-index: 2; filter: hue-rotate(0deg) drop-shadow(0 0 14px rgba(120,255,180,.3)); animation: mb-hue 11s linear infinite; }
  @keyframes mb-hue { to { filter: hue-rotate(360deg) drop-shadow(0 0 14px rgba(120,255,180,.3)); } }
  .mb-sky .g { position: absolute; top: 0; left: 0; width: clamp(54px, 7vw, 110px); height: clamp(54px, 7vw, 110px); opacity: .8; will-change: transform; }
  #viz-ground { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; height: clamp(140px, 26vh, 280px); display: block; z-index: 2; pointer-events: none; image-rendering: pixelated; }
  .mb-sound { position: absolute; left: .8rem; bottom: .7rem; z-index: 4; cursor: pointer; font-family: var(--font-mono); font-size: .72rem; color: var(--t2); background: rgba(4,8,6,.7); border: 1px solid var(--border); border-radius: 8px; padding: .35rem .6rem; backdrop-filter: blur(6px); }
  .mb-sound.on { color: #a3ff12; border-color: rgba(163,255,18,.5); }
  .viz-fallback { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--t2); padding: 1rem; text-align: center; z-index: 3; }
  .viz-fallback[hidden] { display: none; }
  @media (prefers-reduced-motion: reduce) { .mb-sky, .mb-hypno svg { animation: none; } }
</style>

<script>
  import Decimal from 'decimal.js';
  Decimal.set({ precision: 44 });

  const stage = document.getElementById('mb-stage');
  function place() { if (!stage) return; const nav = document.querySelector('nav'); const b = nav ? nav.getBoundingClientRect().bottom : 88; stage.style.top = Math.max(0, Math.round(b + 8)) + 'px'; }
  place(); window.addEventListener('resize', place); window.addEventListener('scroll', place, { passive: true });

  // hypnosis spiral: build a logarithmic-ish Archimedean spiral path (CSS rotates it)
  try { const sp = document.getElementById('mb-spiral'); if (sp) { let d = ''; const turns = 16, A = 50 / (turns * 6.28318); for (let t = 0; t <= turns * 6.28318; t += 0.06) { const r = A * t; d += (d ? 'L' : 'M') + (Math.cos(t) * r).toFixed(2) + ' ' + (Math.sin(t) * r).toFixed(2); } sp.setAttribute('d', d); } } catch (e) {}

  const audio = { on: false, bass: 0, mid: 0, treble: 0 };
  let analyser = null, freq = null;
  const soundBtn = document.getElementById('mb-sound');
  if (soundBtn) soundBtn.addEventListener('click', async () => {
    if (audio.on) { audio.on = false; soundBtn.classList.remove('on'); soundBtn.textContent = '🔊 react to sound'; return; }
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const src = ctx.createMediaStreamSource(stream);
      analyser = ctx.createAnalyser(); analyser.fftSize = 256; analyser.smoothingTimeConstant = 0.8;
      freq = new Uint8Array(analyser.frequencyBinCount); src.connect(analyser);
      audio.on = true; soundBtn.classList.add('on'); soundBtn.textContent = '🔊 listening';
    } catch (err) { soundBtn.textContent = '🔇 mic blocked'; }
  });
  function readAudio() {
    if (audio.on && analyser) { analyser.getByteFrequencyData(freq); let lo = 0, mi = 0, hi = 0, n = freq.length; for (let i = 0; i < n; i++) { const v = freq[i] / 255; if (i < n * 0.12) lo += v; else if (i < n * 0.45) mi += v; else hi += v; } audio.bass = Math.min(1, lo / (n * 0.12)); audio.mid = Math.min(1, mi / (n * 0.33)); audio.treble = Math.min(1, hi / (n * 0.55)); }
    else { audio.bass *= 0.92; audio.mid *= 0.92; audio.treble *= 0.92; }
  }

  /* ---------- glyphs: bounce off each other + walls ---------- */
  try {
    const sky = document.getElementById('mb-sky'); const els = sky ? Array.from(sky.querySelectorAll('.g')) : [];
    const bounds = () => stage.getBoundingClientRect(); const B0 = bounds();
    const glyphs = els.map((el) => { const s = el.getBoundingClientRect().width || 80; return { el, r: s / 2, x: Math.random() * Math.max(1, B0.width - s), y: Math.random() * Math.max(1, B0.height - s), vx: (Math.random() * 2 - 1) * 60, vy: (Math.random() * 2 - 1) * 60, a: Math.random() * 360, va: (Math.random() * 2 - 1) * 30 }; });
    window.__mbStepGlyphs = (dt) => {
      const B = bounds(), W = B.width, H = B.height, boost = 1 + audio.mid * 2.2;
      for (const gg of glyphs) { gg.x += gg.vx * dt * boost; gg.y += gg.vy * dt * boost; gg.a += gg.va * dt * boost; const d = gg.r * 2; if (gg.x < 0) { gg.x = 0; gg.vx = Math.abs(gg.vx); } else if (gg.x + d > W) { gg.x = W - d; gg.vx = -Math.abs(gg.vx); } if (gg.y < 0) { gg.y = 0; gg.vy = Math.abs(gg.vy); } else if (gg.y + d > H) { gg.y = H - d; gg.vy = -Math.abs(gg.vy); } }
      for (let i = 0; i < glyphs.length; i++) for (let j = i + 1; j < glyphs.length; j++) { const a = glyphs[i], b = glyphs[j]; const ax = a.x + a.r, ay = a.y + a.r, bx = b.x + b.r, by = b.y + b.r; let dx = bx - ax, dy = by - ay, dist = Math.hypot(dx, dy) || 0.01, min = a.r + b.r; if (dist < min) { const nx = dx / dist, ny = dy / dist, ov = (min - dist) / 2; a.x -= nx * ov; a.y -= ny * ov; b.x += nx * ov; b.y += ny * ov; const avn = a.vx * nx + a.vy * ny, bvn = b.vx * nx + b.vy * ny; a.vx += (bvn - avn) * nx; a.vy += (bvn - avn) * ny; b.vx += (avn - bvn) * nx; b.vy += (avn - bvn) * ny; } }
      for (const gg of glyphs) gg.el.style.transform = 'translate(' + gg.x.toFixed(1) + 'px,' + gg.y.toFixed(1) + 'px) rotate(' + gg.a.toFixed(1) + 'deg)';
    };
  } catch (e) {}

  /* ---------- auto-playing Game-Boy Egyptian platformer ---------- */
  try {
    const gc = document.getElementById('viz-ground'); const g = gc.getContext('2d'); const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const BODY = ["...rrrrr....","..rrrrrrrr..","..hhhsss.s..",".hshssss.ss.",".hshhsss.ss.",".hhsssssss..","...sssss....","..rroorr....",".rrrooorrr..","rrrooooorrr.","ssrooooorss.","ssoooooooss.","..ooo..ooo.."];
    const LEGS = { run: [[".hhh...hhh..","hhhh...hhhh.","hhh.....hhh."], ["...hhhhhh...","...hhhhhh...","...hh.hh...."]], jump: [".hh....hh...","hh......hh..","............"] };
    const PAL = { r: '#e52521', s: '#f3b78b', h: '#5c3b1e', o: '#3d63c9' };
    let GW = 0, GH = 0, groundY = 0, px = 4, marioH = 64;
    const SEG = 340;
    let world = new Map(), pops = [], dust = [];
    let mx = 0, my = 0, vx = 0, vy = 0, onGround = true, facing = 1, camX = 0;
    let bigUntil = 0, starUntil = 0, coinScore = 0, now = 0, runPhase = 0, squashT = 0, spin = 0;
    let target = null, targetT = 0, idleT = 0;
    function rnd(a, b) { return a + Math.random() * (b - a); }
    function genSeg(i) {
      const base = i * SEG, coins = [], items = [], platforms = [];
      if (Math.random() < 0.6) {
        const w = rnd(60, 130), x = base + rnd(40, SEG - w - 50), py = groundY - GH * rnd(0.3, 0.5);
        platforms.push({ x, y: py, w });
        for (let k = 0; k < 3; k++) coins.push({ x: x + 16 + k * ((w - 28) / 2), y: py - 26, got: false });
        if (Math.random() < 0.45) items.push({ x: x + w * 0.5, y: py - 24, type: Math.random() < 0.5 ? 'mush' : 'star', got: false });
      }
      const cx0 = base + rnd(20, SEG - 150), n = 3 + Math.floor(Math.random() * 3);
      for (let k = 0; k < n; k++) coins.push({ x: cx0 + k * 30, y: groundY - 24 - Math.sin((k + 1) / (n + 1) * Math.PI) * rnd(20, 86), got: false });
      return { platforms, coins, items };
    }
    function ensureWorld() { const cs = Math.floor(camX / SEG); for (let i = cs - 3; i <= cs + 4; i++) if (!world.has(i)) world.set(i, genSeg(i)); for (const i of [...world.keys()]) if (i < cs - 7 || i > cs + 8) world.delete(i); }
    function platsNear() { const out = []; for (const s of world.values()) for (const p of s.platforms) out.push(p); return out; }
    function pickTarget() {
      let best = null, bd = 1e9;
      for (const s of world.values()) {
        for (const c of s.coins) if (!c.got && !c.skip) { const ad = Math.abs(c.x - mx); if (ad < GW * 2.0) { const d = ad + (c.x < mx ? 70 : 0); if (d < bd) { bd = d; best = c; } } }
        for (const it of s.items) if (!it.got && !it.skip) { const ad = Math.abs(it.x - mx); if (ad < GW * 2.2) { const d = ad - 140; if (d < bd) { bd = d; best = it; } } }
      }
      return best;
    }
    function reset() { groundY = GH - Math.max(12, GH * 0.14); px = Math.max(2, Math.round((GH * 0.28) / 16)); marioH = px * 16; world = new Map(); mx = 0; my = groundY; vx = 0; vy = 0; onGround = true; facing = 1; camX = mx - GW * 0.42; bigUntil = 0; starUntil = 0; spin = 0; target = null; targetT = 0; idleT = 0; runPhase = 0; squashT = 0; pops = []; dust = []; ensureWorld(); }
    function gResize() { const r = gc.getBoundingClientRect(); GW = r.width; GH = r.height; gc.width = Math.floor(GW * dpr); gc.height = Math.floor(GH * dpr); g.setTransform(dpr, 0, 0, dpr, 0, 0); g.imageSmoothingEnabled = false; reset(); }
    function pyramid(cx, baseY, size, col) { const step = Math.max(3, Math.floor(size / 8)); g.fillStyle = col; for (let i = 0; i < 8; i++) { const w = size - i * (size / 8); g.fillRect(Math.round(cx - w / 2), Math.round(baseY - (i + 1) * step), Math.round(w), Math.ceil(step)); } }
    function drawMario(cx, feetY, bp, legs, sx, sy, flip, ang) { const pw = bp * sx, ph = bp * sy, frame = BODY.concat(legs); g.save(); g.translate(cx, feetY - 8 * ph); if (ang) g.rotate(ang); if (flip < 0) g.scale(-1, 1); for (let row = 0; row < 16; row++) for (let col = 0; col < 12; col++) { const ch = frame[row][col]; if (ch === '.' || !PAL[ch]) continue; g.fillStyle = PAL[ch]; g.fillRect(Math.round((col - 6) * pw), Math.round((row - 8) * ph), Math.ceil(pw), Math.ceil(ph)); } g.restore(); }
    function drawCoin(x, y) { g.fillStyle = '#ffd400'; g.beginPath(); g.arc(x, y, 7, 0, 6.283); g.fill(); g.fillStyle = '#fff6b0'; g.fillRect(x - 1.5, y - 4, 3, 8); }
    function star5(cx, cy, R) { g.beginPath(); for (let i = 0; i < 10; i++) { const ang = -Math.PI / 2 + i * Math.PI / 5, rr = i % 2 ? R * 0.45 : R, x = cx + Math.cos(ang) * rr, y = cy + Math.sin(ang) * rr; i ? g.lineTo(x, y) : g.moveTo(x, y); } g.closePath(); g.fill(); }
    function drawItem(x, y, type) { if (type === 'mush') { g.fillStyle = '#e23b2e'; g.fillRect(x - 9, y - 9, 18, 10); g.fillStyle = '#fff'; g.fillRect(x - 6, y - 7, 4, 4); g.fillRect(x + 3, y - 7, 4, 4); g.fillStyle = '#f3d9a6'; g.fillRect(x - 6, y + 1, 12, 9); } else { g.fillStyle = '#ffe23a'; star5(x, y, 10); } }
    function drawPlatform(x, y, w) { g.fillStyle = '#b5742f'; g.fillRect(x, y, w, 12); g.fillStyle = '#8a5520'; for (let i = x; i < x + w; i += 14) g.fillRect(i, y, 2, 12); g.fillStyle = '#d89a4a'; g.fillRect(x, y, w, 3); }
    window.__mbGroundResize = gResize;
    window.__mbStepGround = (dt) => {
      now += dt; squashT = Math.max(0, squashT - dt);
      const big = now < bigUntil, mh = marioH * (big ? 1.35 : 1), mw = px * (big ? 1.35 : 1) * 12;
      const G = GH * 6, RUN = GW * 0.2 * (1 + audio.mid * 0.5);
      targetT += dt;
      if (!target || target.got || targetT > 3.4) { if (target && !target.got && targetT > 3.4) target.skip = true; target = pickTarget(); targetT = 0; }
      let desired;
      if (target) { const d = target.x - mx; desired = Math.abs(d) < 6 ? 0 : Math.sign(d) * RUN; idleT = 0; }
      else { idleT += dt; desired = facing * RUN * 0.85; }
      vx += (desired - vx) * Math.min(1, dt * 7);
      if (Math.abs(vx) > RUN * 0.12) facing = vx < 0 ? -1 : 1;
      mx += vx * dt; runPhase += Math.abs(vx) * dt * 0.05;
      if (onGround && target && target.y < groundY - 30 && Math.abs(target.x - mx) < 90) { const need = Math.max(24, groundY - target.y + 16); vy = -Math.sqrt(2 * G * Math.min(GH * 0.62, need)); onGround = false; }
      else if (onGround && !target && idleT > 1.2 && Math.random() < 0.02) { vy = -Math.sqrt(2 * G * GH * 0.18); onGround = false; idleT = 0; }
      const wasAir = !onGround; vy += G * dt; const prevFeet = my; my += vy * dt; onGround = false;
      if (my >= groundY) { my = groundY; vy = 0; onGround = true; }
      for (const p of platsNear()) if (vy >= 0 && prevFeet <= p.y + 5 && my >= p.y && my <= p.y + 22 && mx + mw * 0.5 > p.x && mx - mw * 0.5 < p.x + p.w) { my = p.y; vy = 0; onGround = true; }
      if (my - mh < 6) { my = mh + 6; if (vy < 0) vy = 0; }
      if (wasAir && onGround) { squashT = 0.14; for (let k = 0; k < 6; k++) dust.push({ x: mx, y: my, vx: rnd(-50, 50), vy: rnd(-40, -6), life: 0.42 }); }
      camX += ((mx - GW * (facing > 0 ? 0.4 : 0.6)) - camX) * Math.min(1, dt * 3.4);
      ensureWorld();
      const by = my - mh;
      for (const s of world.values()) {
        for (const c of s.coins) if (!c.got && Math.abs(c.x - mx) < mw * 0.5 + 9 && c.y > by - 10 && c.y < my + 10) { c.got = true; coinScore++; pops.push({ x: c.x, y: c.y, life: 1, txt: '+' }); }
        for (const it of s.items) if (!it.got && Math.abs(it.x - mx) < mw * 0.5 + 12 && it.y > by - 14 && it.y < my + 12) { it.got = true; if (it.type === 'mush') bigUntil = now + 8; else starUntil = now + 7; pops.push({ x: it.x, y: it.y - 6, life: 1, txt: it.type === 'mush' ? '1UP' : '★' }); }
      }
      spin = now < starUntil ? spin + dt * 9 : 0;
      for (const d of dust) { d.x += d.vx * dt; d.y += d.vy * dt; d.vy += GH * 4 * dt; d.life -= dt; }
      dust = dust.filter(d => d.life > 0);
      for (const p of pops) { p.y -= 30 * dt; p.life -= dt; }
      pops = pops.filter(p => p.life > 0);
      g.clearRect(0, 0, GW, GH);
      const span = 420, off = ((camX * 0.5) % span + span) % span;
      for (let k = -1; k * span - off < GW + span; k++) { const x = k * span - off + 160; pyramid(x, groundY + 2, GH * 0.5, '#b07d3a'); pyramid(x + 200, groundY + 2, GH * 0.34, '#9c6d30'); }
      g.fillStyle = '#caa15a'; g.fillRect(0, groundY, GW, GH - groundY); g.fillStyle = '#e6c074'; g.fillRect(0, groundY, GW, Math.max(3, GH * 0.03));
      for (const s of world.values()) {
        for (const p of s.platforms) { const x = p.x - camX; if (x < GW + 40 && x + p.w > -40) drawPlatform(x, p.y, p.w); }
        for (const c of s.coins) if (!c.got) { const x = c.x - camX; if (x > -20 && x < GW + 20) drawCoin(x, c.y); }
        for (const it of s.items) if (!it.got) { const x = it.x - camX; if (x > -24 && x < GW + 24) drawItem(x, it.y, it.type); }
      }
      const ds = Math.max(2, px * 0.6); g.fillStyle = 'rgba(232,206,150,0.7)';
      for (const d of dust) { g.globalAlpha = Math.max(0, d.life / 0.42); g.fillRect(d.x - camX - ds * 0.5, d.y - ds, ds, ds); }
      g.globalAlpha = 1;
      let sx = 1, sy = 1;
      if (!onGround) { sy = 1 + Math.min(0.22, Math.abs(vy) * 0.0009); sx = 2 - sy; }
      else if (squashT > 0) { const u = squashT / 0.14; sy = 1 - 0.2 * u; sx = 1 + 0.2 * u; }
      const bp = px * (big ? 1.35 : 1);
      const legs = !onGround ? LEGS.jump : LEGS.run[Math.floor(runPhase) % 2];
      if (!(now < starUntil && Math.floor(now * 20) % 2 === 0)) drawMario(mx - camX, my, bp, legs, sx, sy, facing, spin);
      for (const p of pops) { g.globalAlpha = Math.max(0, p.life); g.fillStyle = '#fff'; g.font = 'bold 12px monospace'; g.fillText(p.txt, p.x - camX - 6, p.y); g.globalAlpha = 1; }
      g.fillStyle = '#ffd400'; g.beginPath(); g.arc(15, 15, 6, 0, 6.283); g.fill(); g.fillStyle = '#fff'; g.font = 'bold 13px monospace'; g.fillText('x' + coinScore, 25, 19);
    };
    gResize();
  } catch (e) {}

  /* ---------- Mandelbrot via perturbation theory (WebGL2) ---------- */
  const canvas = document.getElementById('viz-mandel');
  const gl = canvas ? canvas.getContext('webgl2', { antialias: false }) : null;
  if (!gl) { const fb = document.getElementById('viz-mandel-fb'); if (fb) fb.hidden = false; }
  else {
    const vs = '#version 300 es\nin vec2 p; void main(){ gl_Position = vec4(p, 0.0, 1.0); }';
    const fs = [
      '#version 300 es', 'precision highp float;',
      'uniform vec2 u_res; uniform float u_scale; uniform float u_iter; uniform int u_refLen; uniform float u_flow; uniform sampler2D u_ref;',
      'out vec4 outColor;',
      'vec2 cm(vec2 a, vec2 b){ return vec2(a.x*b.x - a.y*b.y, a.x*b.y + a.y*b.x); }',
      'vec2 R(int i){ return texelFetch(u_ref, ivec2(min(i, u_refLen-1), 0), 0).xy; }',
      'void main(){',
      '  vec2 uv = (gl_FragCoord.xy - 0.5*u_res)/u_res.y;',
      '  vec2 dc = uv * u_scale;',           // delta-c for this pixel (small, FP32 ok)
      '  vec2 dz = vec2(0.0); int ri = 0; float n = 0.0; vec2 z = vec2(0.0); bool esc = false; vec2 Zc = R(0);',
      '  for(int k=0;k<2200;k++){',
      '    if(n >= u_iter) break;',
      '    dz = cm(2.0*Zc, dz) + cm(dz, dz) + dc;',
      '    ri++; Zc = R(ri);',
      '    z = Zc + dz;',
      '    n += 1.0;',
      '    if(dot(z,z) > 256.0){ esc = true; break; }',
      '    if(ri >= u_refLen-1 || dot(z,z) < dot(dz,dz)){ dz = z; ri = 0; Zc = R(0); }',
      '  }',
      '  if(!esc){ outColor = vec4(0.01,0.02,0.015,1.0); return; }',
      '  float sn = n + 1.0 - log(log(sqrt(dot(z,z))))/log(2.0);',
      '  vec3 a=vec3(0.05,0.12,0.08), b=vec3(0.45,0.55,0.45), c=vec3(1.0,1.0,1.0), d=vec3(0.30,0.10,0.55);',
      '  outColor = vec4(a + b*cos(6.28318*(c*(sn*0.045 + u_flow)+d)), 1.0);',
      '}'
    ].join('\n');
    function sh(t, s) { const o = gl.createShader(t); gl.shaderSource(o, s); gl.compileShader(o); return o; }
    const prog = gl.createProgram(); gl.attachShader(prog, sh(gl.VERTEX_SHADER, vs)); gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, fs)); gl.linkProgram(prog); gl.useProgram(prog);
    const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
    const loc = gl.getAttribLocation(prog, 'p'); gl.enableVertexAttribArray(loc); gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
    const uRes = gl.getUniformLocation(prog, 'u_res'), uScale = gl.getUniformLocation(prog, 'u_scale'), uIter = gl.getUniformLocation(prog, 'u_iter'), uRefLen = gl.getUniformLocation(prog, 'u_refLen'), uFlow = gl.getUniformLocation(prog, 'u_flow'), uRef = gl.getUniformLocation(prog, 'u_ref');
    const tex = gl.createTexture(); gl.bindTexture(gl.TEXTURE_2D, tex); gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST); gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST); gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE); gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.uniform1i(uRef, 0);

    let q = 0.7, fAcc = 0, fCnt = 0; const qMax = Math.min(1.25, window.devicePixelRatio || 1);
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    // high-precision dive targets (points on the set boundary, ~33 sig digits)
    const TARGETS = [
      { re: '-0.743643887037158704752191506114774', im: '0.131825904205311970493132056385139' }
    ];
    const MAXREF = 2600;
    let scale = 1.6, iter = 320, flow = 0, refLen = 0, idle = 200, dragging = false, lastX = 0, lastY = 0, recompT = 0;
    let cx = new Decimal(TARGETS[0].re), cy = new Decimal(TARGETS[0].im);
    const fade = document.getElementById('mb-fade');

    function refPrecision() { return Math.max(40, Math.ceil(-Math.log10(Math.max(1e-300, scale))) + 18); }
    function computeRef() {
      Decimal.set({ precision: refPrecision() });
      const RX = new Decimal(cx), RY = new Decimal(cy);
      let zx = new Decimal(0), zy = new Decimal(0); const data = new Float32Array(MAXREF * 2); let len = MAXREF;
      for (let nn = 0; nn < MAXREF; nn++) {
        data[nn * 2] = Number(zx); data[nn * 2 + 1] = Number(zy);
        const nzx = zx.times(zx).minus(zy.times(zy)).plus(RX); const nzy = zx.times(zy).times(2).plus(RY);
        zx = nzx; zy = nzy;
        if (zx.times(zx).plus(zy.times(zy)).gt(4)) { len = nn + 1; break; }
      }
      gl.bindTexture(gl.TEXTURE_2D, tex);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RG32F, len, 1, 0, gl.RG, gl.FLOAT, data.subarray(0, len * 2));
      refLen = len;
    }
    function scheduleRecompute() { clearTimeout(recompT); recompT = setTimeout(computeRef, 130); }
    computeRef();

    function resize() { const r = canvas.getBoundingClientRect(); canvas.width = Math.max(1, Math.floor(r.width * q)); canvas.height = Math.max(1, Math.floor(r.height * q)); gl.viewport(0, 0, canvas.width, canvas.height); }
    function render() { iter = Math.min(1200, 300 + Math.floor(Math.log2(1.6 / scale)) * 42); gl.uniform2f(uRes, canvas.width, canvas.height); gl.uniform1f(uScale, scale); gl.uniform1f(uIter, iter); gl.uniform1i(uRefLen, refLen); gl.uniform1f(uFlow, flow); gl.drawArrays(gl.TRIANGLES, 0, 3); }

    // drag to pan, wheel to zoom: move the high-precision center, then re-derive the reference orbit
    canvas.addEventListener('pointerdown', (e) => { dragging = true; lastX = e.clientX; lastY = e.clientY; idle = 0; try { canvas.setPointerCapture(e.pointerId); } catch (_) {} });
    canvas.addEventListener('pointerup', () => { dragging = false; scheduleRecompute(); });
    canvas.addEventListener('pointercancel', () => { dragging = false; });
    canvas.addEventListener('pointermove', (e) => { if (!dragging) return; idle = 0; const r = canvas.getBoundingClientRect(); const k = scale / r.height; cx = cx.minus((e.clientX - lastX) * k); cy = cy.plus((e.clientY - lastY) * k); lastX = e.clientX; lastY = e.clientY; });
    canvas.addEventListener('wheel', (e) => { e.preventDefault(); idle = 0; const r = canvas.getBoundingClientRect(); const ax = (e.clientX - r.left - r.width / 2) / r.height, ay = -(e.clientY - r.top - r.height / 2) / r.height; const ns = Math.min(3.0, Math.max(1e-300, scale * Math.exp(e.deltaY * 0.0012))); cx = cx.plus(ax * (scale - ns)); cy = cy.plus(ay * (scale - ns)); scale = ns; scheduleRecompute(); }, { passive: false });

    function stepFractal(dt) {
      fAcc += dt; fCnt++;
      if (fCnt >= 45) { const avg = fAcc / fCnt; if (avg > 0.0215 && q > 0.4) { q = Math.max(0.4, q - 0.12); resize(); } else if (avg < 0.016 && q < qMax) { q = Math.min(qMax, q + 0.08); resize(); } fAcc = 0; fCnt = 0; }
      if (!reduce) {
        flow += dt * (0.04 + audio.bass * 0.9 + audio.mid * 0.5);
        if (!dragging) {
          idle++;
          if (idle > 90) {
            scale *= 0.9965;
            if (scale < 1e-10) { cx = new Decimal(TARGETS[0].re); cy = new Decimal(TARGETS[0].im); scale = 1.6; if (fade) fade.style.opacity = '1'; setTimeout(() => { computeRef(); if (fade) fade.style.opacity = '0'; }, 460); }
          }
        }
      }
      render();
    }
    const ro = new ResizeObserver(() => { resize(); if (window.__mbGroundResize) window.__mbGroundResize(); });
    resize(); ro.observe(canvas); window.__mbStepFractal = stepFractal;
  }

  /* ---------- master loop ---------- */
  let last = 0, raf = 0, alive = true;
  function loop(ts) { if (!alive) return; const dt = last ? Math.min(0.05, (ts - last) / 1000) : 0.016; last = ts; readAudio(); try { if (window.__mbStepFractal) window.__mbStepFractal(dt); } catch (e) {} try { if (window.__mbStepGlyphs) window.__mbStepGlyphs(dt); } catch (e) {} try { if (window.__mbStepGround) window.__mbStepGround(dt); } catch (e) {} raf = requestAnimationFrame(loop); }
  raf = requestAnimationFrame(loop);
  document.addEventListener('visibilitychange', () => { if (document.hidden) { alive = false; cancelAnimationFrame(raf); } else if (!alive) { alive = true; last = 0; raf = requestAnimationFrame(loop); } });
</script>
